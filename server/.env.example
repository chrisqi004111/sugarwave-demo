# Tencent Lighthouse Express backend — server-side env vars (names only, no values).
# Set these on the server (systemd Environment= / pm2 ecosystem env / a root-only
# .env loaded by the process). NEVER use VITE_ prefixes here — VITE_ vars are
# build-time frontend vars and would be exposed in the browser bundle.

# Upstash KV (Vercel KV) — MUST be the SAME database/credentials as the Vercel
# deployment so access codes & quota are shared across both deployments.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Providers — same keys as Vercel.
OPENAI_KEY=
REPLICATE_TOKEN=

# Express listen port (Nginx proxy_pass targets this on 127.0.0.1).
PORT=3000

# OpenAI blocks the HK region, so render() forwards the OpenAI image call to a
# Vercel "image-only" endpoint (api/render-relay.js) in a supported region.
# Set BOTH on the HK server. Vercel needs only RENDER_RELAY_SECRET (to validate
# incoming relay calls) and must NOT set RENDER_RELAY_URL (or it would relay to
# itself). Quota is still consumed locally — render is charged exactly once.
# RENDER_RELAY_URL = the Vercel deployment's /api/render-relay (e.g. the
#   dual-deployment branch alias …-git-dual-deployment-….vercel.app/api/render-relay).
# RENDER_RELAY_SECRET = a long random string, identical on HK and Vercel.
RENDER_RELAY_URL=
RENDER_RELAY_SECRET=
